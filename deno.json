{
  "name": "@dep/text",
  "version": "1.0.1",
  "exports": "./src/main.ts",
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "@/": "./src/",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/path": "jsr:@std/path@^1.1.6"
  },
  "tasks": {
    "start": "deno run --allow-net src/main.ts",
    "build": "deno run --allow-read src/build.ts",
    "dev": "deno run --allow-env --allow-net --watch src/main.ts",
    "check-types": "deno check src/**/*.ts && deno publish --check",
    "docs": "lineo md 'src/**/*.ts' --outFile code.md --outDir temp",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "clean": "rm -rf dist",
    "pack": "deno compile -A -o text ./cli.ts",
    "prerelease": "deno lint && deno fmt",
    "release": "deno task prerelease && jsr publish ./"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true,
    "trailingCommas": "onlyMultiLine"
  }
}
